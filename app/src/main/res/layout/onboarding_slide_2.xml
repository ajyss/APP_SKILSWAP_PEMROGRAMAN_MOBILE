<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- PERBAIKAN 1: Nama file gambar diubah dari image_onboarding2 menjadi onboarding2 -->
    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/image_onboarding2"
        android:contentDescription="@string/image_onboarding_content_description" />

    <!-- PERBAIKAN 2: fontFamily diubah menjadi poppins_bold agar konsisten -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="@string/onboarding_title_2"
        android:textColor="@android:color/white"
        android:textSize="24sp" />

</LinearLayout>
