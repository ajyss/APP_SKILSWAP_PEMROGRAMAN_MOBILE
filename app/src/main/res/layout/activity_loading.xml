<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05181F"
    tools:context=".LoadingActivity">

    <!-- Layering ImageView untuk menampilkan latar belakang dan animasi -->
    <ImageView
        android:id="@+id/iv_circle_background"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_circle_path"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45"
        android:contentDescription="Loading background" />

    <ImageView
        android:id="@+id/iv_animated_check"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/anim_success"
        app:layout_constraintBottom_toBottomOf="@id/iv_circle_background"
        app:layout_constraintEnd_toEndOf="@id/iv_circle_background"
        app:layout_constraintStart_toStartOf="@id/iv_circle_background"
        app:layout_constraintTop_toTopOf="@id/iv_circle_background"
        android:contentDescription="Animated check mark" />

    <TextView
        android:id="@+id/tv_loading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:fontFamily="@font/poppins_semibold"
        android:text="Creating You Account!\nSit Tight!"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_animated_check" />

</androidx.constraintlayout.widget.ConstraintLayout>
