<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:gravity="center"
            android:text="Buat Akun"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Premium White Sheet Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_premium_sheet"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Nama Lengkap -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_name"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="Masukkan nama lengkap"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Email"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_email"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="example@example.com"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <!-- Nomer Telepon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Nomer Telepon"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_phone"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="+ 123 456 789"
                android:inputType="phone"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <!-- Tanggal Lahir -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tanggal Lahir"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_dob"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="DD / MM / YYYY"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <!-- Kata Sandi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Kata Sandi"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_password"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="●●●●●●●●"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <!-- Konfirmasi Kata Sandi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Konfirmasi Kata Sandi"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_reg_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="●●●●●●●●"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="By continuing, you agree to\nTerms of Use and Privacy Policy."
                android:textColor="@color/skillswap_text_secondary"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_register_submit"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/indicator_active"
                android:backgroundTint="@color/skillswap_emerald"
                android:text="Sign Up"
                android:textAllCaps="false"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_btn_ke_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Already have an account? Log In"
                android:textColor="@color/skillswap_blue_deep"
                android:textStyle="bold"
                android:textSize="13sp" />

            <!-- Space for scrolling -->
            <View android:layout_width="match_parent" android:layout_height="80dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
