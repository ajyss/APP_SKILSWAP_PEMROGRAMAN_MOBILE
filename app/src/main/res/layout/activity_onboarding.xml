<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_bg_dark">

    <!-- 1. HEADER AREA (STATIS / TIDAK IKUT SLIDE) -->
    <LinearLayout
        android:id="@+id/layout_header_fixed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="16dp"
                android:src="@drawable/flag_id" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="ID"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Judul ini akan kita ubah lewat Java biar sinkron dengan slide -->
        <TextView
            android:id="@+id/tv_fixed_title"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Selamat Datang Di\nSkillSwap"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2. VIEW PAGER UNTUK PANEL PUTIH (YANG BISA DI-SLIDE) -->
    <!-- Kita kasih margin top biar dia mulai dari bawah header -->
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPagerOnboarding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header_fixed"
        android:layout_marginTop="10dp" />

    <!-- 3. INDIKATOR TITIK (DI ATAS PANEL PUTIH TERBAWAH) -->
    <me.relex.circleindicator.CircleIndicator
        android:id="@+id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        app:ci_drawable="@drawable/indicator_active"
        app:ci_drawable_unselected="@drawable/indicator_inactive" />

</RelativeLayout>
