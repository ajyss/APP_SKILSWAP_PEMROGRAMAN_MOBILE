<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/skillswap_card_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_swapper_profile"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/profil" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/iv_swapper_profile"
            android:layout_toStartOf="@id/btn_swap_request"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_swapper_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sporsha Paul"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/anim_success" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_swapper_skills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Blender 4.0 | Game Developer 4.2"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:alpha="0.9" />

            <TextView
                android:id="@+id/tv_swapper_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Passionate game developer with 5+ years experience building..."
                android:textColor="@color/white"
                android:textSize="10sp"
                android:alpha="0.7"
                android:maxLines="2" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_swap_request"
            android:layout_width="110dp"
            android:layout_height="35dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/indicator_active"
            android:backgroundTint="#262833"
            android:text="Send Swap Request"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>
