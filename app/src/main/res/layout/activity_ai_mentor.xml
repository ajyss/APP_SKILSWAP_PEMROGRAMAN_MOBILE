<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_ai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Mentor"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tanya apapun tentang skill yang ingin kamu pelajari."
            android:textColor="#E0E0E0"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Chat Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ai_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/input_area"
        android:layout_below="@+id/header_ai"
        android:clipToPadding="false"
        android:padding="16dp" />

    <!-- Progress Bar (Sembunyi saat tidak berpikir) -->
    <ProgressBar
        android:id="@+id/pb_ai_loading"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:indeterminateTint="@android:color/white" />

    <!-- Input Area (Liquid Glass) -->
    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/glass_panel_background"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_margin="16dp">

        <EditText
            android:id="@+id/et_ai_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Tanya sesuatu..."
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:textColorHint="#B0FFFFFF" />

        <ImageButton
            android:id="@+id/btn_send_ai"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_send"
            app:tint="@android:color/white" />
    </LinearLayout>

</RelativeLayout>
