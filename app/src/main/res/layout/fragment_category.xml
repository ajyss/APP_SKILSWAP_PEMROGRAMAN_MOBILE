<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_sheet_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori Keahlian"
            android:textColor="@color/skillswap_dark_blue"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pilih kategori untuk menemukan partner yang tepat."
            android:textColor="@color/skillswap_text_light"
            android:textSize="14sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:columnCount="2">

            <!-- Koding -->
            <include
                android:id="@+id/cat_coding"
                layout="@layout/item_category_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1" />

            <!-- Bahasa -->
            <include
                android:id="@+id/cat_language"
                layout="@layout/item_category_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1" />

            <!-- Desain -->
            <include
                android:id="@+id/cat_design"
                layout="@layout/item_category_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1" />

            <!-- Bisnis -->
            <include
                android:id="@+id/cat_business"
                layout="@layout/item_category_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1" />

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Kategori lainnya akan segera ditambahkan!"
            android:textAlignment="center"
            android:textColor="@color/skillswap_text_light"
            android:textSize="12sp"
            android:paddingBottom="50dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
