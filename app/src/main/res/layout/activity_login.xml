<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_bg_dark"
    android:orientation="vertical">

    <!-- Header Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:text="Selamat Datang"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- White Sheet Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_premium_sheet"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pengguna / Email"
            android:textColor="@color/skillswap_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_login_user"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="@color/skillswap_soft_green"
            android:hint="Masukkan email Anda"
            android:paddingHorizontal="20dp"
            android:textColor="@color/skillswap_text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Kata Sandi"
            android:textColor="@color/skillswap_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_login_pass"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="@color/skillswap_soft_green"
            android:hint="●●●●●●●●"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:textColor="@color/skillswap_text_primary"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_masuk_submit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/indicator_active"
            android:backgroundTint="@color/skillswap_emerald"
            android:text="Masuk"
            android:textAllCaps="false"
            android:textColor="@color/skillswap_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_btn_ke_daftar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Belum punya akun? Daftar Sekarang"
            android:textColor="@color/skillswap_text_primary"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
