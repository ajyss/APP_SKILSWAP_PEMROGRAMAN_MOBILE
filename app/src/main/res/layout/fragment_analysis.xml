<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_bg_dark"
    android:orientation="vertical">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ANALISIS SKILL"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            app:cardBackgroundColor="@color/skillswap_soft_green"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ai_stars"
                app:tint="@color/skillswap_bg_dark" />
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <!-- White Sheet Panel -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_premium_sheet"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Search Inputs -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/skillswap_soft_green"
                android:hint="Apa yang ingin Anda pelajari?"
                android:paddingHorizontal="20dp"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="13sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/btn_search_action"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_input_field"
                    android:backgroundTint="@color/skillswap_soft_green"
                    android:hint="Keahlian apa yang ingin ditukar?"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/skillswap_text_primary"
                    android:textSize="13sp" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_search_action"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    app:cardBackgroundColor="@color/skillswap_emerald"
                    app:cardCornerRadius="14dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_analysis"
                        app:tint="@color/skillswap_bg_dark" />
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Rekomendasi Partner Untuk Anda:"
                android:textColor="@color/skillswap_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Search Results List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <View android:layout_width="match_parent" android:layout_height="120dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
