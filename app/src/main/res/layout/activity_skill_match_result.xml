<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skillswap_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:layout_marginTop="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Match"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/indicator_active"
                android:backgroundTint="@color/skillswap_soft_green"
                android:padding="6dp"
                android:src="@drawable/ic_notification"
                app:tint="@color/skillswap_bg_dark" />
        </RelativeLayout>

        <!-- Main Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="24dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="@color/skillswap_soft_green">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_check_path"
                    app:tint="@color/skillswap_emerald" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp">
                    
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_match_me"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/profil"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/white"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iv_match_me"
                        android:layout_centerVertical="true"
                        android:layout_marginHorizontal="12dp"
                        android:orientation="vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_forward" app:tint="@color/skillswap_emerald"/>
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_forward" android:rotation="180" app:tint="@color/skillswap_emerald" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_match_other"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_toEndOf="@id/iv_match_me"
                        android:layout_marginLeft="48dp"
                        android:src="@drawable/fotopria1"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/white"/>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Congratulations!.\nYou Can Swap Your Skill"
                    android:textColor="@color/skillswap_bg_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_send_message_match"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:background="@drawable/indicator_active"
                    android:backgroundTint="@color/skillswap_emerald"
                    android:paddingHorizontal="32dp"
                    android:text="Send Message"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        
        <View android:layout_width="match_parent" android:layout_height="100dp"/>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
