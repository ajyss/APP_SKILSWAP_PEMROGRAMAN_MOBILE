<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 1. TEMA UTAMA: GAYA PREMIUM DARK TEAL -->
    <style name="Theme.ProjectSkillSwap" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Warna Status Bar & Navigation Bar Sistem -->
        <item name="android:statusBarColor">@color/skillswap_bg_dark</item>
        <item name="android:navigationBarColor">@color/skillswap_bg_dark</item>
        <item name="android:windowBackground">@color/skillswap_bg_dark</item>
        
        <!-- Warna Primer & Sekunder Material Design -->
        <item name="colorPrimary">@color/skillswap_emerald</item>
        <item name="colorSecondary">@color/skillswap_soft_green</item>
    </style>

    <!-- 2. TEMA KHUSUS SPLASH SCREEN (MENCEGAH CRASH SAAT BOOT) -->
    <style name="Theme.AppSplash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/skillswap_bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.ProjectSkillSwap</item>
    </style>

</resources>
