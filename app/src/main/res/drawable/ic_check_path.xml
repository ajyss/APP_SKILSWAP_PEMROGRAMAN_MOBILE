<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="120">

    <!-- Grup ini akan dianimasikan -->
    <group
        android:name="check_and_circle_group"
        android:pivotX="60"
        android:pivotY="60">

        <!-- Path untuk Lingkaran Hijau -->
        <path
            android:name="circle"
            android:pathData="M60,60m-55,0a55,55 0,1 1,110 0a55,55 0,1 1,-110 0"
            android:strokeWidth="4"
            android:strokeColor="#4CAF50"
            android:strokeLineCap="round"
            android:trimPathEnd="0" /> <!-- Awalnya tidak terlihat -->

        <!-- Path untuk Tanda Centang -->
        <path
            android:name="check"
            android:pathData="M33,60 l20,20 l35,-35"
            android:strokeWidth="5"
            android:strokeColor="#4CAF50"
            android:strokeLineCap="round"
            android:trimPathEnd="0" /> <!-- Awalnya tidak terlihat -->
    </group>
</vector>
